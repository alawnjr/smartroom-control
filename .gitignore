# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# pipeline runtime logs (detect.py / action.py)
.detect.log
.action.log

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Saved recordings pulled from the nodes (Save All) — not version-controlled
/recordings/

# action recognition venv (mmcv/mmaction2, py3.10) — rebuilt via detect/setup-action-env.sh
.venv-action/

# Python bytecode
__pycache__/
*.pyc

# local action-class whitelist (written by the Classes tab)
action-classes.json
